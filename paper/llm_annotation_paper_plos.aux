\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces MLLM pseudo-label annotation accuracy and retention rate on the validation split. ``Pseudo-label acc.'' = percentage of pseudo-labels matching the ground-truth label for retained bbox crops. Under the None strategy, ``Retained'' is the number of crops with a valid Qwen index; Qwen produces valid outputs for more than 99.9\% of validation crops. These retention rates are computed on the validation split only; training-set retention rates used later in the retention-ratio analysis are reported separately in the text and figure.\relax }}{11}{table.caption.33}\protected@file@percent }
\newlabel{tab:annotation_quality}{{5}{11}{MLLM pseudo-label annotation accuracy and retention rate on the validation split. ``Pseudo-label acc.'' = percentage of pseudo-labels matching the ground-truth label for retained bbox crops. Under the None strategy, ``Retained'' is the number of crops with a valid Qwen index; Qwen produces valid outputs for more than 99.9\% of validation crops. These retention rates are computed on the validation split only; training-set retention rates used later in the retention-ratio analysis are reported separately in the text and figure.\relax }{table.caption.33}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces BowTurnHead validation-set confusion counts for Qwen and LLaVA. Rows denote ground-truth labels; columns denote model predictions.\relax }}{11}{table.caption.34}\protected@file@percent }
\newlabel{tab:bow_confusion}{{6}{11}{BowTurnHead validation-set confusion counts for Qwen and LLaVA. Rows denote ground-truth labels; columns denote model predictions.\relax }{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Per-category MLLM annotation accuracy on TeacherBehavior (Agreement strategy, validation split). Accuracy is reported to two decimal places to match the other quantitative tables.\relax }}{12}{table.caption.36}\protected@file@percent }
\newlabel{tab:per_class}{{7}{12}{Per-category MLLM annotation accuracy on TeacherBehavior (Agreement strategy, validation split). Accuracy is reported to two decimal places to match the other quantitative tables.\relax }{table.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-category MLLM annotation reliability on TeacherBehavior under the Agreement strategy. Categories with explicit visual anchors are annotated reliably, whereas categories requiring intent inference drop to near-zero accuracy in the reported setting.\relax }}{12}{figure.caption.37}\protected@file@percent }
\newlabel{fig:visual_anchoring}{{2}{12}{Per-category MLLM annotation reliability on TeacherBehavior under the Agreement strategy. Categories with explicit visual anchors are annotated reliably, whereas categories requiring intent inference drop to near-zero accuracy in the reported setting.\relax }{figure.caption.37}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Representative crops from the TeacherBehavior validation agreement subset. High-anchor classes are associated with localized visual cues, whereas low-anchor intent-defined classes remain visually close to generic classroom interaction. The agreement accuracies shown above each category match Table\nobreakspace  {}\ref  {tab:per_class}.\relax }}{13}{figure.caption.38}\protected@file@percent }
\newlabel{fig:visual_anchoring_examples}{{3}{13}{Representative crops from the TeacherBehavior validation agreement subset. High-anchor classes are associated with localized visual cues, whereas low-anchor intent-defined classes remain visually close to generic classroom interaction. The agreement accuracies shown above each category match Table~\ref {tab:per_class}.\relax }{figure.caption.38}{}}
\newlabel{sec:finetune_results}{{}{13}{Fine-Tuning Results}{section*.39}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Validation accuracy (\%) of CLIP ViT-L/14 under all experimental conditions. LP values report mean $\pm $ SD over repeated seeds (all datasets: five seeds, 43--47); LoRA values report mean $\pm $ SD for the targeted five-seed replication conditions (BowTurnHead and TeacherBehavior under None and GT; seeds 43--47) and seed-42 protocol-matched references elsewhere. \textbf  {Bold} = best result per dataset. ZS = zero-shot CLIP baseline (no fine-tuning). LP = linear probe. LoRA = low-rank adaptation. The repeated-seed LoRA cells therefore correspond only to those four replicated conditions; see Finding\nobreakspace  {}5 for the associated curve analysis.\relax }}{13}{table.caption.40}\protected@file@percent }
\newlabel{tab:main_results}{{8}{13}{Validation accuracy (\%) of CLIP ViT-L/14 under all experimental conditions. LP values report mean $\pm $ SD over repeated seeds (all datasets: five seeds, 43--47); LoRA values report mean $\pm $ SD for the targeted five-seed replication conditions (BowTurnHead and TeacherBehavior under None and GT; seeds 43--47) and seed-42 protocol-matched references elsewhere. \textbf {Bold} = best result per dataset. ZS = zero-shot CLIP baseline (no fine-tuning). LP = linear probe. LoRA = low-rank adaptation. The repeated-seed LoRA cells therefore correspond only to those four replicated conditions; see Finding~5 for the associated curve analysis.\relax }{table.caption.40}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Overview of the full evaluation matrix. The plot includes the three zero-shot baselines and all 18 CLIP fine-tuning conditions formed by three datasets, three label sources, and two fine-tuning methods. Solid bars denote repeated or replicated conditions; hatched bars denote single-run references; error bars show $\pm 1$ SD when available. ZS = zero-shot CLIP; LP = linear probing; LoRA = low-rank adaptation; Agree = agreement-filtered pseudo-labels. Here, ZS bars follow the baseline zero-shot setting used in Table\nobreakspace  {}\ref  {tab:main_results} (\texttt  {step0b\_cape\_zeroshot.py}); LP bars use repeated-seed means, whereas LoRA bars combine the targeted five-seed replication values for BowTurnHead and TeacherBehavior under None and GT with protocol-matched seed-42 references elsewhere. Prompt-ensemble zero-shot values are reported separately in the selective-analysis section.\relax }}{14}{figure.caption.41}\protected@file@percent }
\newlabel{fig:all_results_overview}{{4}{14}{Overview of the full evaluation matrix. The plot includes the three zero-shot baselines and all 18 CLIP fine-tuning conditions formed by three datasets, three label sources, and two fine-tuning methods. Solid bars denote repeated or replicated conditions; hatched bars denote single-run references; error bars show $\pm 1$ SD when available. ZS = zero-shot CLIP; LP = linear probing; LoRA = low-rank adaptation; Agree = agreement-filtered pseudo-labels. Here, ZS bars follow the baseline zero-shot setting used in Table~\ref {tab:main_results} (\texttt {step0b\_cape\_zeroshot.py}); LP bars use repeated-seed means, whereas LoRA bars combine the targeted five-seed replication values for BowTurnHead and TeacherBehavior under None and GT with protocol-matched seed-42 references elsewhere. Prompt-ensemble zero-shot values are reported separately in the selective-analysis section.\relax }{figure.caption.41}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Five-model cross-model robustness check of validation-set annotation accuracy under a common bbox-crop and index-only prompting protocol. Qwen2 = Qwen2-VL-7B-Instruct; LLaVA = LLaVA-1.5-7B; Qwen2.5-7B = Qwen2.5-VL-7B-Instruct; Qwen2.5-32B = Qwen2.5-VL-32B-Instruct; Gemma-3-27B = Gemma-3-27B-IT. Values are bbox-level pseudo-label accuracy (\%).\relax }}{14}{table.caption.43}\protected@file@percent }
\newlabel{tab:crossmodel_overall}{{9}{14}{Five-model cross-model robustness check of validation-set annotation accuracy under a common bbox-crop and index-only prompting protocol. Qwen2 = Qwen2-VL-7B-Instruct; LLaVA = LLaVA-1.5-7B; Qwen2.5-7B = Qwen2.5-VL-7B-Instruct; Qwen2.5-32B = Qwen2.5-VL-32B-Instruct; Gemma-3-27B = Gemma-3-27B-IT. Values are bbox-level pseudo-label accuracy (\%).\relax }{table.caption.43}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Cross-model validation on the two clearest intent-dependent TeacherBehavior categories. Values are validation-set bbox-level accuracy (\%). n = number of validation crops for the category.\relax }}{15}{table.caption.44}\protected@file@percent }
\newlabel{tab:crossmodel_intent}{{10}{15}{Cross-model validation on the two clearest intent-dependent TeacherBehavior categories. Values are validation-set bbox-level accuracy (\%). n = number of validation crops for the category.\relax }{table.caption.44}{}}
\newlabel{sec:discussion}{{}{15}{Discussion}{section*.45}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Class-composition shift between the full training split and the agreement subset for each dataset. Labels on the agreement bars report percentage-point change relative to the full training distribution, making the direction and magnitude of selection bias explicit.\relax }}{16}{figure.caption.47}\protected@file@percent }
\newlabel{fig:distribution_shift}{{5}{16}{Class-composition shift between the full training split and the agreement subset for each dataset. Labels on the agreement bars report percentage-point change relative to the full training distribution, making the direction and magnitude of selection bias explicit.\relax }{figure.caption.47}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Retention-ratio curves for BowTurnHead, HandriseReadWrite, and TeacherBehavior under linear probing with unfiltered pseudo-labels (None strategy), augmented with the agreement-filtered endpoint (labelled ``Agree''). All plotted points are fixed-seed diagnostic runs (seed 42), whereas Table\nobreakspace  {}\ref  {tab:main_results} reports repeated-seed LP means for the main downstream comparison. The x-axis reports \emph  {training-set} retention rates, whereas Table\nobreakspace  {}\ref  {tab:annotation_quality} reports \emph  {validation-set} retention rates for annotation quality. Random subsampling remains stable above the critical retention threshold for all three datasets. The agreement-selected endpoint falls far below the random-retention trend for BowTurnHead and HandriseReadWrite, whereas TeacherBehavior shows only a small positive deviation.\relax }}{17}{figure.caption.49}\protected@file@percent }
\newlabel{fig:retention_curve}{{6}{17}{Retention-ratio curves for BowTurnHead, HandriseReadWrite, and TeacherBehavior under linear probing with unfiltered pseudo-labels (None strategy), augmented with the agreement-filtered endpoint (labelled ``Agree''). All plotted points are fixed-seed diagnostic runs (seed 42), whereas Table~\ref {tab:main_results} reports repeated-seed LP means for the main downstream comparison. The x-axis reports \emph {training-set} retention rates, whereas Table~\ref {tab:annotation_quality} reports \emph {validation-set} retention rates for annotation quality. Random subsampling remains stable above the critical retention threshold for all three datasets. The agreement-selected endpoint falls far below the random-retention trend for BowTurnHead and HandriseReadWrite, whereas TeacherBehavior shows only a small positive deviation.\relax }{figure.caption.49}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Comparison of annotation strategies on TeacherBehavior (validation accuracy, \%). The selective strategy uses pseudo-labels for high-anchor classes and zero-shot CLIP for low-anchor classes. High-anchor: blackboard-writing, teacher, screen, blackboard. Low-anchor: guide, answer, on-stage interaction, stand. The zero-shot baseline in this table uses the prompt-ensemble setting. \textbf  {Selective routing uses ground-truth category as oracle routing variable at evaluation time and represents a diagnostic upper bound, not a deployable pipeline.}\relax }}{18}{table.caption.54}\protected@file@percent }
\newlabel{tab:selective_results}{{11}{18}{Comparison of annotation strategies on TeacherBehavior (validation accuracy, \%). The selective strategy uses pseudo-labels for high-anchor classes and zero-shot CLIP for low-anchor classes. High-anchor: blackboard-writing, teacher, screen, blackboard. Low-anchor: guide, answer, on-stage interaction, stand. The zero-shot baseline in this table uses the prompt-ensemble setting. \textbf {Selective routing uses ground-truth category as oracle routing variable at evaluation time and represents a diagnostic upper bound, not a deployable pipeline.}\relax }{table.caption.54}{}}
